<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/homeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="@dimen/home_top_padding_default"
        android:paddingEnd="28dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:id="@+id/homeTopRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="top"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/homeTopInfoColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/clockView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_clock_margin_top_default"
                    android:fontFamily="@font/work_sans_light"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.01"
                    android:textColor="@color/black"
                    android:textSize="52sp" />

                <TextView
                    android:id="@+id/dateView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/work_sans_regular"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.02"
                    android:textColor="@color/black"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/batteryView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:drawablePadding="6dp"
                    android:fontFamily="@font/work_sans_regular"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.02"
                    android:textColor="@color/black"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/teslaStatusView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/work_sans_regular"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.02"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/teslaWidgetSlot"
                android:layout_width="@dimen/tesla_widget_size"
                android:layout_height="@dimen/tesla_widget_size"
                android:layout_marginStart="@dimen/tesla_widget_gap"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/teslaWidgetContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:id="@+id/teslaWidgetPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tesla_widget_placeholder"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/work_sans_regular"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/home_widget_placeholder"
                        android:textColor="@color/black"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeContentRow"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/home_content_margin_top_default"
            android:layout_weight="1"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/favoritesColumn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="13"
                android:gravity="top|end"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/favoritesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/integrationColumn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="18dp"
                android:layout_weight="7"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/calendarPanel"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/calendarItemsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/gtdPanel"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/gtdTitleView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/home_gtd_title"
                            android:textColor="@color/black"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/gtdAddButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/work_sans_regular"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minWidth="36dp"
                            android:minHeight="36dp"
                            android:paddingStart="8dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="4dp"
                            android:paddingBottom="4dp"
                            android:text="@string/home_gtd_add"
                            android:textColor="@color/black"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/gtdDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/ink_divider" />

                    <LinearLayout
                        android:id="@+id/gtdItemsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/browseContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="20dp"
            android:paddingEnd="28dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/queryView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_search_minimal"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/work_sans_regular"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.02"
                    android:text="@string/search_hint"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="16dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/settings_title"
                    android:padding="2dp"
                    android:src="@drawable/ic_settings_minimal"
                    app:tint="@color/black" />
            </LinearLayout>

            <View
                android:id="@+id/searchDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/ink_divider" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/settingsScrollContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="18dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/settingsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settingsNameView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/work_sans_medium"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/settings_app_name"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/settingsRevisionView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/work_sans_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/settings_revision"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/settingsAppNameSizeLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_app_name_size_label"
                            android:textColor="@color/black"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/settingsAppNameSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/black"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/settingsAppNameSizeHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/work_sans_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/settings_app_name_size_hint"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:alpha="0.64" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/settingsDarkModeLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_dark_mode_label"
                            android:textColor="@color/black"
                            android:textSize="16sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/settingsDarkModeSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/settingsDarkModeHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/work_sans_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/settings_dark_mode_hint"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:alpha="0.64" />

                    <TextView
                        android:id="@+id/settingsChromeLinkAddButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/work_sans_regular"
                        android:includeFontPadding="false"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/settings_chrome_link_add"
                        android:textColor="@color/black"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/settingsChromeLinkHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/work_sans_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/settings_chrome_link_hint"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:alpha="0.64" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/settingsIntegrationLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_integration_label"
                            android:textColor="@color/black"
                            android:textSize="16sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/settingsIntegrationSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/settingsIntegrationHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/work_sans_regular"
                        android:includeFontPadding="false"
                        android:letterSpacing="0.02"
                        android:text="@string/settings_integration_requires_apps"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:alpha="0.64" />

                    <LinearLayout
                        android:id="@+id/settingsTeslaSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/settingsTeslaLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/work_sans_regular"
                                android:includeFontPadding="false"
                                android:letterSpacing="0.02"
                                android:text="@string/settings_widget_label"
                                android:textColor="@color/black"
                                android:textSize="16sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/settingsTeslaSwitch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/settingsTeslaHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_widget_hint"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:alpha="0.64" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/settingsWidgetExpandedLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/work_sans_regular"
                                android:includeFontPadding="false"
                                android:letterSpacing="0.02"
                                android:text="@string/settings_widget_expanded_label"
                                android:textColor="@color/black"
                                android:textSize="15sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/settingsWidgetExpandedSwitch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/settingsWidgetExpandedHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_widget_expanded_hint"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:alpha="0.64" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/settingsWidgetDebugLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/work_sans_regular"
                                android:includeFontPadding="false"
                                android:letterSpacing="0.02"
                                android:text="@string/settings_widget_debug_label"
                                android:textColor="@color/black"
                                android:textSize="15sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/settingsWidgetDebugSwitch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/settingsWidgetDebugHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_widget_debug_hint"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:alpha="0.64" />

                        <TextView
                            android:id="@+id/settingsTeslaStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/work_sans_regular"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.02"
                            android:text="@string/settings_widget_off"
                            android:textColor="@color/black"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/settingsTeslaConfigureButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/work_sans_regular"
                                android:includeFontPadding="false"
                                android:paddingStart="4dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="2dp"
                                android:text="@string/settings_widget_choose"
                                android:textColor="@color/black"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/settingsTeslaRefreshButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/work_sans_regular"
                                android:includeFontPadding="false"
                                android:paddingStart="4dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="2dp"
                                android:text="@string/settings_widget_change"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/settingsTeslaDisconnectButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/work_sans_regular"
                                android:includeFontPadding="false"
                                android:paddingStart="4dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="2dp"
                                android:text="@string/settings_widget_clear"
                                android:textColor="@color/black"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/appListView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="0dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pageIndicatorContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/contextMenuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <LinearLayout
                android:id="@+id/contextMenuCard"
                android:layout_width="272dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_context_menu_card"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/contextMenuTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/work_sans_medium"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.02"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <View
                    android:id="@+id/contextMenuDivider"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/black" />

                <LinearLayout
                    android:id="@+id/contextMenuActionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/contextMenuCloseButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_context_menu_close"
                android:contentDescription="@string/cancel"
                android:padding="12dp"
                android:src="@drawable/ic_context_close"
                android:translationX="18dp"
                android:translationY="-18dp"
                app:tint="@color/black" />
        </FrameLayout>
    </FrameLayout>
</FrameLayout>
